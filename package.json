{
  "name": "ocfg",
  "version": "0.1.0",
  "description": "OpenCode provider configuration editor.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "SECURITY.md"
  ],
  "keywords": [
    "opencode",
    "provider",
    "cli",
    "tui",
    "jsonc"
  ],
  "bin": {
    "ocfg": "dist/cli.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^14.0.2",
    "ink": "^6.5.1",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
