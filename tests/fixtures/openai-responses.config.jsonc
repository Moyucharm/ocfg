{
  "$schema": "https://opencode.ai/config.json",
  // OpenAI Responses endpoint fixture.
  "provider": {
    "openai": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI Responses",
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5": {
          "name": "GPT-5",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "variants": {
            "low": { "reasoningEffort": "low" },
            "high": { "reasoningEffort": "high" }
          }
        }
      }
    }
  },
  "model": "openai/gpt-5"
}
