{
  "$schema": "https://opencode.ai/config.json",
  // Claude-compatible Anthropic Messages endpoint fixture.
  "provider": {
    "custom-claude": {
      "npm": "@ai-sdk/anthropic",
      "name": "Custom Claude Compatible",
      "options": {
        "baseURL": "https://example.com/v1",
        "apiKey": "{env:CUSTOM_CLAUDE_API_KEY}",
        "setCacheKey": true
      },
      "models": {
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 Compatible",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "options": {
            "thinking": { "type": "enabled", "budgetTokens": 16000 }
          }
        }
      }
    }
  },
  "model": "custom-claude/claude-sonnet-4-5"
}
