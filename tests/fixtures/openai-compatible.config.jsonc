{
  "$schema": "https://opencode.ai/config.json",
  // OpenAI-compatible chat completions endpoint fixture.
  "provider": {
    "custom-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Custom OpenAI Compatible",
      "options": {
        "baseURL": "https://example.com/v1",
        "apiKey": "{env:CUSTOM_OPENAI_API_KEY}",
        "setCacheKey": true
      },
      "models": {
        "gpt-5-compatible": {
          "name": "GPT-5 Compatible",
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "attachment": true,
          "tool_call": true,
          "temperature": true
        }
      }
    }
  },
  "model": "custom-openai/gpt-5-compatible"
}
