{
  "$schema": "https://opencode.ai/config.json",
  // OpenAI-compatible chat completions endpoint fixture.
  "provider": {
    "custom-openai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Custom OpenAI Compatible",
      "options": {
        "baseURL": "https://example.com/v1",
        "apiKey": "{env:CUSTOM_OPENAI_API_KEY}",
        "setCacheKey": true
      },
      "models": {
        "gpt-5": {
          "name": "GPT-5 Compatible",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": false,
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            }
          }
        }
      }
    }
  },
  "model": "custom-openai/gpt-5"
}
