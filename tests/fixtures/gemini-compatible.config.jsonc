{
  "$schema": "https://opencode.ai/config.json",
  // Gemini-compatible Google Generative AI endpoint fixture.
  "provider": {
    "custom-gemini": {
      "npm": "@ai-sdk/google",
      "name": "Custom Gemini Compatible",
      "options": {
        "baseURL": "https://generativelanguage.googleapis.com/v1beta",
        "apiKey": "{env:CUSTOM_GEMINI_API_KEY}"
      },
      "models": {
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro Compatible",
          "limit": {
            "context": 1000000,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf", "audio", "video"],
            "output": ["text"]
          },
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "temperature": true
        }
      }
    }
  },
  "model": "custom-gemini/gemini-2.5-pro"
}
